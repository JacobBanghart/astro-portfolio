---
import BaseLayout from "../layouts/BaseLayout.astro";

import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout
  title="About | Jacob Banghart"
  description="Software Engineer II at Disney Streaming with experience in subscription commerce, distributed systems, and platform reliability."
>
  <div class="stack gap-20">
    <main class="wrapper about">
      <Hero
        title="About"
        tagline="Thanks for stopping by. Read below to learn more about myself and my background."
      >
        <img
          width="1553"
          height="873"
          src="/assets/at-play.webp"
          alt="Jacob Banghart enjoying a magic convention"
          class="contain"
        />
      </Hero>

      <section>
        <h2 class="section-title">Background</h2>
        <div class="content">
          <p>
            I am a Software Engineer II at Disney Streaming with 5+ years of
            professional experience building full-stack applications, APIs, and
            production systems. Today I work on the subscription commerce
            platform that powers billing, offer presentation, and plan
            management across Disney+, Hulu, and ESPN+ on web, mobile, and TV
            devices.
          </p>
          <p>
            My work spans API design, feature delivery, developer tooling, and
            production reliability. I have led end-to-end delivery for
            subscription retention offers across multiple regional launches,
            owned infrastructure migrations with Terraform and Datadog, and
            supported launch readiness through on-call, debugging, and same-day
            hotfixes. I also enjoy cross-team technical alignment, code review,
            and helping teams adopt practical AI-assisted development workflows.
          </p>
          <p>
            Before Disney, I worked at CNH building business APIs, event-driven
            systems, and observability tooling across AWS, Azure, Kubernetes,
            and SQL Server. Earlier in my career, I built full-stack financial
            software at LMS Project and interactive real-time frontends for
            autonomous systems. I completed a Master&apos;s degree in Computer and
            Information Systems with a specialization in Data Management at
            Dakota State University.
          </p>
        </div>
      </section>
      <section>
        <h2 class="section-title">Education</h2>
        <div class="content">
          <p>
            Masters of Computer Information Systems - Dakota State University
            (3.55 GPA)
          </p>
        </div>
      </section>
      <section>
        <h2 class="section-title">Skills</h2>
        <div class="content">
          <ul class="skills-ul">
            <li>JavaScript</li>
            <li>TypeScript</li>
            <li>React *</li>
            <li>REST APIs</li>
            <li>GraphQL</li>
            <li>Node.js</li>
            <li>NestJS</li>
            <li>Next.js</li>
            <li>SQL Server</li>
            <li>AWS</li>
            <li>Azure</li>
            <li>Terraform</li>
            <li>Astro *</li>
            <li>Express</li>
            <li>CI/CD *</li>
            <li>Kubernetes *</li>
            <li>Docker *</li>
            <li>Datadog</li>
            <li>OpenTelemetry</li>
          </ul>
        </div>
        <div class="content">
          <p>* This site is currently using this technology</p>
        </div>
      </section>
    </main>

    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  img {
    margin-top: 1.5rem;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--gray-200);
  }

  .section-title {
    grid-column-start: 1;
    font-size: var(--text-xl);
    color: var(--gray-0);
  }

  .content {
    grid-column: 2 / 4;
  }

  .content :global(a) {
    text-decoration: 1px solid underline transparent;
    text-underline-offset: 0.25em;
    transition: text-decoration-color var(--theme-transition);
  }

  .content :global(a:hover),
  .content :global(a:focus) {
    text-decoration-color: currentColor;
  }

  @media (min-width: 50em) {
    .about {
      display: grid;
      grid-template-columns: 1fr 60% 1fr;
    }

    .about > :global(:first-child) {
      grid-column-start: 2;
    }

    section {
      display: contents;
      font-size: var(--text-lg);
    }
    .skills-ul {
      columns: 2;
      -webkit-columns: 2;
      -moz-columns: 2;
    }
  }
</style>
